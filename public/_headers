# Cache policy (honoured by Netlify / Cloudflare Pages; ignored by hosts that don't use _headers).
#
# index.html must NEVER be cached: it carries the <script> tags that point at the
# current hashed chunk filenames. If a browser keeps an old index.html it will keep
# requesting old chunk hashes that no longer exist after a deploy, which crashes
# lazy-loaded pages with "Failed to fetch dynamically imported module".
/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed build assets are content-addressed, so they can be cached forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
