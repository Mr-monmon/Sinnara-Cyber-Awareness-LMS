# ──────────────────────────────────────────────────────────────────────────
# Frontend (Vite) — exposed to the browser; only put PUBLIC values here.
# ──────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_VERSION=0.0.0
# Sentry — leave blank to disable browser error monitoring (safe for dev).
VITE_SENTRY_DSN=

# ──────────────────────────────────────────────────────────────────────────
# Supabase Edge Function secrets — set in:
#   Supabase Dashboard → Edge Functions → Secrets  (NEVER commit real values).
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected by
# the platform automatically; the rest are configured by you.
# ──────────────────────────────────────────────────────────────────────────

# Server-side error monitoring for Edge Functions (optional).
SENTRY_DSN=

# AES key used to encrypt stored SMTP profile passwords (hex 64 chars or
# base64url 43 chars). REQUIRED for the phishing SMTP feature.
SMTP_ENCRYPTION_KEY=

# Allow sending via SMTP profiles whose password is NOT yet encrypted.
# Keep "false" (or unset) in production — fail closed on plaintext secrets.
ALLOW_PLAINTEXT_SMTP=false

# ZeptoMail (Zoho) API token for transactional email.
# IMPORTANT: store the RAW token only — do NOT include the "Zoho-enczapikey"
# prefix. The code adds it via buildZeptoAuthHeader() and will NOT double-prefix
# if you accidentally include it, but the documented convention is RAW token.
#   Correct : ZEPTOMAIL_TOKEN=wSsVR61...rawtoken...
#   Tolerated: ZEPTOMAIL_TOKEN=Zoho-enczapikey wSsVR61...   (prefix stripped)
ZEPTOMAIL_TOKEN=

# One-time backfill endpoint guard (user-admin). Optional; if set, callers may
# pass this secret instead of a PLATFORM_ADMIN JWT.
BACKFILL_SECRET=

# Landing-page cloning render backends (optional; enable SPA capture).
RENDER_SERVICE_URL=
BROWSERLESS_URL=
BROWSERLESS_TOKEN=
SCRAPINGBEE_KEY=
